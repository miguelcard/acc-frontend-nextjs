<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows cleartext (plain HTTP) traffic to the Android emulator's host alias and the dev machine's LAN IP.
    10.0.2.2 is the special IP that the Android emulator uses to reach the host machine's localhost.
    192.168.0.128 is the dev machine's LAN IP for testing on a real physical device.
    This is needed for local development only — production should always use HTTPS.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">192.168.0.128</domain>
    </domain-config>
</network-security-config>
